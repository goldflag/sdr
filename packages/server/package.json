{
  "name": "@sdr/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "test:dsp": "bun run src/dsp/selftest.ts",
    "test:adsb": "bun run src/dsp/adsb-selftest.ts",
    "test:ais": "bun run src/dsp/ais-selftest.ts",
    "test:aprs": "bun run src/dsp/aprs-selftest.ts",
    "test:ism": "bun run src/dsp/ism-selftest.ts",
    "test:rds": "bun run src/dsp/rds-selftest.ts"
  },
  "dependencies": {
    "@sdr/shared": "workspace:*",
    "fft.js": "^4.0.4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
